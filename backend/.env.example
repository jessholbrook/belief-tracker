# Required: get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: shared bearer token. When set, all /api routes (except /api/health)
# and the chat WebSocket require it. Give the same value to the frontend build
# as VITE_API_TOKEN.
API_AUTH_TOKEN=

# Optional
MODEL=claude-sonnet-4-6
MAX_TOKENS=16384
DB_PATH=./data/app.db
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
LOG_LEVEL=INFO
